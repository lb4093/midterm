	}
	fill(0);
	textSize(25);
	text('Press A!', 2, 25);
	text('Press Z!', 102, 25);
	text('Press S!', 202, 25);
	text('Press X!', 302, 25);
}

function mouseClicked() {
	animated = 0;
}

function mouseDragged() {
	animated = 1;
}

function keyPressed() {
	if (key !== 'a') {
		y = y + 100;
		if (y > 250) {
			y = 0;
		}
	}
	if (key === 'a') {
		x = x + 100;
		if (x > 250) {
			x = 0;
		}
	}
	if (key === 'z') {
		animated = 2;
	}
	if (key === 'x') {
		animated = 3;
	}
	if (key === 's') {
		animated = 4;
	}
}

function drawCurve(leftY, rightY) {
	let stable = frameCount % 32;
	let step = floor(stable / 4);
	curve(
		mouseX,
		mouseY + leftY[step],
		mouseX - 200,
		mouseY,
		mouseX + 200,
		mouseY,
		mouseX,
		mouseY + rightY[step]
	);
}

