function draw() {
	print(animated);
	background(mouseX / 3.2, mouseY / 3.2, y);
	fill(mouseX - 300, mouseY - 300, x);
	if (animated === 0) {
		drawCurve(leftY, rightY);
	} else if (animated === 1) {
		drawCurve2(leftY2, rightY2);
	} else if (animated === 2) {
		drawCurve3(leftY3, rightY3);
	} else if (animated === 3) {

		drawCurve3(leftY4, rightY4);
	}
	fill(300, mouseX - 300, x)
	if (animated === 0) {
		drawCurve4(leftY, rightY);
		drawCurve6(leftY, rightY);
	} else if (animated === 1) {
		drawCurve5(leftY2, rightY2);
		drawCurve7(leftY2, rightY2);
	} else if (animated === 2) {
		drawCurve5(leftY3, rightY3);
		drawCurve7(leftY3, rightY3);
	} else if (animated === 3) {
		drawCurve5(leftY4, rightY4);
		drawCurve7(leftY4, rightY4);
	} else if (animated === 4) {
		drawCurve5(leftY5, rightY5);
